#!/usr/bin/env sh

# No scripting addition on this machine for now: keep SIP fully enabled.
# This preserves the everyday tiling workflow but skips Spaces/sticky/layer tricks.

yabai -m config layout bsp

# Keep the old laptop's no-gap feel. Revisit later if we want breathing room.
# yabai -m config left_padding 8
# yabai -m config top_padding 8
# yabai -m config bottom_padding 8
# yabai -m config right_padding 8
# yabai -m config window_gap 8

yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Finder$" manage=off
yabai -m rule --add app="^Stats$" manage=off
yabai -m rule --add app="^MonitorControl$" manage=off
yabai -m rule --add app="^Raycast$" manage=off
yabai -m rule --add app="^Simulator$" manage=off
yabai -m rule --add app="^Notes$" manage=off
yabai -m rule --add title="^/dev/cu.usbmodem140111$" manage=off
yabai -m rule --add app="^rerun$" manage=on
