######################
# --- move focus --- #

# between windows
alt - l : yabai -m window --focus east
alt - j : yabai -m window --focus west
alt - k : yabai -m window --focus south
alt - i : yabai -m window --focus north

# between monitors
alt - o : yabai -m display --focus east
alt - u : yabai -m display --focus west

# in a stack
alt - tab : yabai -m window --focus stack.next || yabai -m window --focus stack.first
alt + shift - tab : yabai -m window --focus stack.prev || yabai -m window --focus stack.last


#######################
# --- move window --- #

# within space
shift + alt - l : yabai -m window --swap east
shift + alt - j : yabai -m window --swap west
shift + alt - k : yabai -m window --swap south
shift + alt - i : yabai -m window --swap north

ctrl + shift + alt - l : yabai -m window --warp east
ctrl + shift + alt - j : yabai -m window --warp west
ctrl + shift + alt - k : yabai -m window --warp south
ctrl + shift + alt - i : yabai -m window --warp north


#########################
# --- resize window --- #

ctrl + alt - j : yabai -m window --resize left:-20:0
ctrl + alt - l : yabai -m window --resize right:20:0
ctrl + alt - i : yabai -m window --resize top:0:-20
ctrl + alt - k : yabai -m window --resize bottom:0:20

ctrl + cmd + alt - l : yabai -m window --resize left:20:0
ctrl + cmd + alt - j : yabai -m window --resize right:-20:0
ctrl + cmd + alt - k : yabai -m window --resize top:0:20
ctrl + cmd + alt - i : yabai -m window --resize bottom:0:-20

ctrl + alt - space : yabai -m space --balance
ctrl + cmd + alt - space : yabai -m window --toggle float
alt + shift - space : yabai -m space --layout bsp
alt + shift + ctrl - space : yabai -m space --layout stack
